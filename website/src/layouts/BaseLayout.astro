---
import packageMeta from "../../../package.json";
import "../styles/foundation.css";
import "../styles/layout.css";
import "../styles/ui.css";

const {
  title = "causal-order",
  description = "Event integrity for distributed systems that cannot treat timestamp order alone as the truth model.",
  imagePath = "/pwa-icon-512.png",
  noindex = false,
  pathname = Astro.url.pathname,
  type = "website",
} = Astro.props;

const packageVersion = packageMeta.version;
const currentYear = new Date().getFullYear();
const siteOrigin = Astro.site?.toString().replace(/\/$/, "") ?? "";
const canonicalUrl = siteOrigin ? new URL(pathname, `${siteOrigin}/`).toString() : "";
const imageUrl = siteOrigin && imagePath
  ? new URL(imagePath, `${siteOrigin}/`).toString()
  : "";
const robotsContent = noindex ? "noindex, nofollow" : "index, follow";
const twitterCard = imageUrl ? "summary" : "summary";

const themeBootScript = `
  (() => {
    const stored = localStorage.getItem("causal-order-theme");
    const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
    const theme = stored === "light" || stored === "dark" ? stored : (systemDark ? "dark" : "light");
    document.documentElement.dataset.theme = theme;
    document.documentElement.style.colorScheme = theme;
  })();
`;

const themeToggleScript = `
  (() => {
    const root = document.documentElement;
    const button = document.querySelector("[data-theme-toggle]");

    if (!button) {
      return;
    }

    const applyTheme = (theme) => {
      root.dataset.theme = theme;
      root.style.colorScheme = theme;
      button.setAttribute("aria-pressed", String(theme === "dark"));
      button.setAttribute("aria-label", theme === "dark" ? "Switch to light mode" : "Switch to dark mode");
      localStorage.setItem("causal-order-theme", theme);
    };

    button.addEventListener("click", () => {
      const next = root.dataset.theme === "dark" ? "light" : "dark";
      applyTheme(next);
    });

    applyTheme(root.dataset.theme === "dark" ? "dark" : "light");
  })();
`;

const registerServiceWorkerScript = `
  (() => {
    if (!("serviceWorker" in navigator)) {
      return;
    }

    const getSameOriginAssetUrls = () => {
      const urls = new Set([window.location.pathname + window.location.search]);
      const selectors = [
        'link[rel="stylesheet"]',
        'link[rel="modulepreload"]',
        'script[src]',
      ];

      for (const selector of selectors) {
        for (const element of document.querySelectorAll(selector)) {
          const rawUrl = element.href || element.src;
          if (!rawUrl) {
            continue;
          }

          const url = new URL(rawUrl, window.location.origin);
          if (url.origin !== window.location.origin) {
            continue;
          }

          urls.add(url.pathname + url.search);
        }
      }

      return [...urls];
    };

    const cacheCurrentPageShell = (registration) => {
      if (!registration?.active) {
        return;
      }

      registration.active.postMessage({
        type: "CACHE_URLS",
        urls: getSameOriginAssetUrls(),
      });
    };

    window.addEventListener("load", () => {
      navigator.serviceWorker
        .register("/sw.js")
        .then((registration) => {
          cacheCurrentPageShell(registration);
          return navigator.serviceWorker.ready;
        })
        .then((registration) => {
          cacheCurrentPageShell(registration);
        })
        .catch((error) => {
          console.warn("Service worker registration failed", error);
        });
    });
  })();
`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:site_name" content="causal-order" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    <meta name="application-name" content="causal-order" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="causal-order" />
    <meta name="theme-color" content="#f6f4ec" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#081311" media="(prefers-color-scheme: dark)" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon-180.png" />
    <link rel="mask-icon" href="/pwa-maskable.svg" color="#0f766e" />
    <script is:inline set:html={themeBootScript}></script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-shell">
        <div class="brand">
          <a class="brand-mark-link" href="/" aria-label="Go to homepage">
            <span class="brand-mark" aria-hidden="true">
              <svg viewBox="0 0 42 42" class="brand-mark-svg" role="img" aria-label="causal-order mark">
                <defs>
                  <linearGradient id="brandMarkGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#0f766e" />
                    <stop offset="100%" stop-color="#2a9d8f" />
                  </linearGradient>
                </defs>
                <rect x="0" y="0" width="42" height="42" rx="14" fill="url(#brandMarkGradient)"></rect>
                <path
                  d="M10.5 24.5C14.5 24.5 16 21.5 20.5 21.5C24.5 21.5 26.5 18 31.5 18"
                  fill="none"
                  stroke="#effcf8"
                  stroke-width="2.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
                <circle cx="10.5" cy="24.5" r="3.4" fill="#f8fafc" />
                <circle cx="20.5" cy="21.5" r="2.8" fill="#fbbf24" />
                <circle cx="31.5" cy="18" r="3.4" fill="#fb7185" />
              </svg>
            </span>
          </a>
          <div class="brand-text">
            <div class="brand-title-row">
              <a class="brand-title-link" href="/">causal-order</a>
              <a
                class="npm-badge"
                href="https://www.npmjs.com/package/causal-order"
                target="_blank"
                rel="noreferrer"
                aria-label="View causal-order on npm"
              >
                <span class="npm-badge-label">npm</span>
                <span class="npm-badge-version">v{packageVersion}</span>
              </a>
            </div>
            <span class="brand-meta">
              <small>event integrity for distributed systems</small>
            </span>
          </div>
        </div>

        <nav class="top-nav" aria-label="Main">
          <a href="/guides/">Guides</a>
          <a href="/wiki/">Wiki</a>
          <a href="/api/">API</a>
          <a
            href="https://github.com/GazaliAhmad/causal-order"
            target="_blank"
            rel="noreferrer"
            aria-label="View causal-order on GitHub"
            class="nav-icon-link"
          >
            <svg viewBox="0 0 24 24" class="nav-icon" aria-hidden="true">
              <path
                d="M12 2C6.48 2 2 6.58 2 12.23c0 4.52 2.87 8.35 6.84 9.7.5.1.68-.22.68-.5 0-.25-.01-1.06-.01-1.92-2.78.62-3.37-1.21-3.37-1.21-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.63.07-.63 1 .08 1.53 1.06 1.53 1.06.9 1.57 2.35 1.12 2.92.86.09-.67.35-1.12.63-1.37-2.22-.26-4.56-1.14-4.56-5.08 0-1.12.39-2.03 1.03-2.75-.11-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.33 9.33 0 0 1 12 6.84a9.3 9.3 0 0 1 2.5.35c1.9-1.33 2.74-1.05 2.74-1.05.56 1.41.21 2.45.11 2.71.64.72 1.03 1.63 1.03 2.75 0 3.95-2.35 4.81-4.59 5.07.36.32.68.93.68 1.88 0 1.36-.01 2.45-.01 2.79 0 .27.18.6.69.49A10.2 10.2 0 0 0 22 12.23C22 6.58 17.52 2 12 2Z"
                fill="currentColor"
              />
            </svg>
          </a>
          <button type="button" class="theme-toggle" data-theme-toggle aria-pressed="false">
            <span class="theme-toggle-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" class="nav-icon theme-icon-sun" data-theme-icon="sun">
                <path
                  d="M12 3.75v1.5m0 13.5v1.5m8.25-8.25h-1.5M5.25 12h-1.5m13.114 5.864-1.06-1.06M8.196 8.196l-1.06-1.06m9.728 0-1.06 1.06M8.196 15.804l-1.06 1.06M12 7.25a4.75 4.75 0 1 0 0 9.5 4.75 4.75 0 0 0 0-9.5Z"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              <svg viewBox="0 0 24 24" class="nav-icon theme-icon-moon" data-theme-icon="moon">
                <path
                  d="M15.64 2.83c-3.27.86-5.64 3.9-5.64 7.47 0 4.25 3.45 7.7 7.7 7.7 1.44 0 2.79-.4 3.94-1.08a8.5 8.5 0 1 1-6-14.09Z"
                  fill="currentColor"
                />
              </svg>
            </span>
          </button>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-shell">
        <p>
          © {currentYear}
          <a href="https://gazali.one" target="_blank" rel="noreferrer">gazali.one</a>
        </p>
        <a href="/privacy/">Privacy</a>
      </div>
    </footer>
    <script is:inline set:html={themeToggleScript}></script>
    {import.meta.env.PROD && <script is:inline set:html={registerServiceWorkerScript}></script>}
  </body>
</html>
