---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/status.css";
---

<BaseLayout title="Not Found | causal-order" noindex={true}>
  <section class="not-found">
    <div class="not-found-visual">
      <img src="/404-broken-doc.svg" alt="Broken document illustration for a page that could not be found." />
    </div>
    <div class="not-found-copy">
      <p class="card-kicker">Oops, it&apos;s a 404</p>
      <h1>That page is not here.</h1>
      <p>
        The address may be broken, outdated, or pointing at a page that no longer exists. Try the
        practical guides, the conceptual wiki, or go back to the homepage.
      </p>
    </div>
    <div class="not-found-actions hero-actions">
      <a class="button button-primary" href="/">Home</a>
      <a class="button button-secondary" href="/guides/">Guides</a>
      <a class="button button-secondary" href="/wiki/">Wiki</a>
    </div>
  </section>
</BaseLayout>
