---
import ApiLayout from "../../layouts/ApiLayout.astro";
import { apiNavigation, apiPages } from "../../lib/api.js";

export function getStaticPaths() {
  return Object.values(apiPages)
    .filter((page) => page.href !== "/api/types/")
    .map((page) => ({
      params: {
        slug: page.href.replace(/^\/api\/|\/$/g, ""),
      },
      props: { page },
    }));
}

const { page } = Astro.props;
const replacementPage = page.deprecated?.replacementName
  ? apiPages[page.deprecated.replacementName] ?? null
  : null;

const toc = [
  ...(page.deprecated ? [{ id: "deprecation", text: "Deprecated", depth: 2 }] : []),
  { id: "signature", text: "Signature", depth: 2 },
  ...(page.usage ? [{ id: "usage", text: "Usage", depth: 2 }] : []),
  ...(page.bullets.length > 0 ? [{ id: "details", text: "Details", depth: 2 }] : []),
];
---

<ApiLayout
  title={page.title}
  description={page.description}
  sourceUrl={page.sourceUrl}
  toc={toc}
  navigation={apiNavigation}
  currentPath={page.href}
>
  {page.deprecated && (
    <>
      <h2 id="deprecation">Deprecated</h2>
      <div class="api-callout api-callout-warning">
        <p>
          <span class="api-status api-status-deprecated">Deprecated</span>
          {` Published deprecation since ${page.deprecated.since}.`}
        </p>
        <p set:html={page.deprecated.message} />
        {replacementPage && (
          <p>
            Prefer <a href={replacementPage.href}><code>{page.deprecated.replacementLabel}</code></a>.
          </p>
        )}
      </div>
    </>
  )}

  <h2 id="signature">Signature</h2>
  {page.signatures.map((signature) => (
    <pre><code>{signature}</code></pre>
  ))}

  {page.summary && <p set:html={page.summary} />}

  {page.usage && (
    <>
      <h2 id="usage">Usage</h2>
      <pre><code>{page.usage}</code></pre>
    </>
  )}

  {page.bullets.length > 0 && (
    <>
      <h2 id="details">Details</h2>
      <ul>
        {page.bullets.map((bullet) => (
          <li set:html={bullet} />
        ))}
      </ul>
    </>
  )}
</ApiLayout>
