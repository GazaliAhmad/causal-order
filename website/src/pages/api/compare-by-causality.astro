---
import ApiLayout from "../../layouts/ApiLayout.astro";
import { apiNavigation, apiPages } from "../../lib/api.js";

const page = apiPages.compareByCausality;

const toc = [
  { id: "signature", text: "Signature", depth: 2 },
  { id: "usage", text: "Usage", depth: 2 },
  { id: "possible-results", text: "Possible results", depth: 2 },
  { id: "supported-evidence", text: "Supported evidence", depth: 2 },
];
---

<ApiLayout
  title={page.title}
  description={page.description}
  sourceUrl={page.sourceUrl}
  toc={toc}
  navigation={apiNavigation}
  currentPath={page.href}
>
  <h2 id="signature">Signature</h2>
  {page.signatures.map((signature) => (
    <pre><code>{signature}</code></pre>
  ))}

  <h2 id="usage">Usage</h2>
  <pre><code>{`import { compareByCausality } from "causal-order"

const relation = compareByCausality(eventA, eventB)

if (relation === "before") {
  console.log("A is before B")
} else if (relation === "unknown") {
  console.log("The library cannot justify the pairwise relationship")
}`}</code></pre>

  <h2 id="possible-results">Possible results</h2>
  <ul>
    <li><code>before</code></li>
    <li><code>after</code></li>
    <li><code>equal</code></li>
    <li><code>unknown</code></li>
  </ul>

  <p>
    The current exported pairwise contract does not promote unsupported cross-node cases into a
    first-class <code>concurrent</code> result. In the current runtime, many conceptually
    independent cases remain <code>unknown</code>.
  </p>

  <h2 id="supported-evidence">Supported evidence</h2>
  <ul>
    <li><code>parentEventId</code></li>
    <li><code>dependencyEventIds</code></li>
    <li>same-node monotonic <code>sequence</code></li>
  </ul>
</ApiLayout>
