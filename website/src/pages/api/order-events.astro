---
import ApiLayout from "../../layouts/ApiLayout.astro";
import { apiNavigation, apiPages } from "../../lib/api.js";

const page = apiPages.orderEvents;

const toc = [
  { id: "signature", text: "Signature", depth: 2 },
  { id: "usage", text: "Usage", depth: 2 },
  { id: "what-it-returns", text: "What it returns", depth: 2 },
  { id: "main-options", text: "Main options", depth: 2 },
];
---

<ApiLayout
  title={page.title}
  description={page.description}
  sourceUrl={page.sourceUrl}
  toc={toc}
  navigation={apiNavigation}
  currentPath={page.href}
>
  <h2 id="signature">Signature</h2>
  {page.signatures.map((signature) => (
    <pre><code>{signature}</code></pre>
  ))}

  <p>
    This is the main bounded-batch entry point. It validates input, builds ordering constraints from
    supported causal evidence, and emits a deterministic result even when full proof is not available.
  </p>

  <h2 id="usage">Usage</h2>
  <pre><code>{`import { orderEvents } from "causal-order"

const result = orderEvents(events, {
  strict: false,
  detectAnomalies: true,
  tieBreaker: "event_id",
})

console.log(result.ordered)
console.log(result.anomalies)
console.log(result.stats)`}</code></pre>

  <h2 id="what-it-returns">What it returns</h2>
  <ul>
    <li><code>ordered</code>: ordered events with <code>orderIndex</code>, <code>orderBasis</code>, and <code>confidence</code>.</li>
    <li><code>anomalies</code>: invalid, suspicious, or operationally important records.</li>
    <li><code>stats</code>: counts for total, valid, invalid, ordered, and anomaly totals.</li>
  </ul>

  <h2 id="main-options">Main options</h2>
  <ul>
    <li><code>tieBreaker</code>: deterministic tie breaker such as <code>event_id</code> or <code>ingestion_order</code>.</li>
    <li><code>strict</code>: throw on invalid or unresolved conditions instead of returning a tolerant result.</li>
    <li><code>detectAnomalies</code>: include anomaly detection in the returned batch result.</li>
    <li><code>allowUnknownOrder</code>: permit unresolved ordering to remain explicit in non-strict mode.</li>
    <li><code>maxClockDriftMs</code>: validation bound for future clock drift checks.</li>
  </ul>
</ApiLayout>
