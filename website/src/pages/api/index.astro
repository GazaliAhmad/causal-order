---
import ApiLayout from "../../layouts/ApiLayout.astro";
import {
  apiExportsByGroup,
  apiNavigation,
  apiOverview,
  apiPages,
  apiPageList,
  apiTypes,
} from "../../lib/api.js";
const functionPageByName = new Map(
  apiPageList.map((page) => [page.title.replace(/\(\)$/, ""), page.href]),
);
const primaryPages = apiPageList.filter((page) => page.primary);

const toc = [
  { id: "where-to-start", text: "Where to start", depth: 2 },
  { id: "focused-entrypoints", text: "Focused entrypoints", depth: 2 },
  { id: "entry-points", text: "Primary entry points", depth: 2 },
  { id: "all-exports", text: "All exports", depth: 2 },
  { id: "public-types", text: "Public types", depth: 2 },
];
---

<ApiLayout
  title={apiOverview.title}
  description={apiOverview.description}
  sourceUrl={apiOverview.sourceUrl}
  toc={toc}
  navigation={apiNavigation}
  currentPath="/api/"
>
  <p>
    The package exports a full top-level surface from <code>src/index.ts</code>, plus focused npm
    subpath entrypoints for narrower import shapes. The API is grouped around translation, event
    ordering, streaming, validation, causality comparison, clocks, anomalies, and types.
  </p>

  <h2 id="where-to-start">Where to start</h2>
  <p>
    If your data is not already in the event-envelope shape, start with <code>translateBatch()</code>.
    Use <code>orderEvents()</code> for bounded replay or audit slices, and move to
    <code>orderEventStream()</code> when you need watermark, late-arrival, and correction-capable
    behavior.
  </p>

  <h2 id="focused-entrypoints">Focused entrypoints</h2>
  <p>
    If you prefer smaller import surfaces, the published package also exposes additive focused
    entrypoints alongside the root <code>causal-order</code> import.
  </p>
  <ul>
    {apiOverview.focusedEntrypoints.map((entrypoint) => (
      <li>
        <code>{entrypoint.path}</code>{` - ${entrypoint.description}`}
      </li>
    ))}
  </ul>

  <h2 id="entry-points">Primary entry points</h2>
  <ul>
    {primaryPages.map((page) => (
      <li>
        <a href={page.href}><code>{page.title}</code></a>
        {page.description ? ` - ${page.description}` : ""}
      </li>
    ))}
  </ul>

  <h2 id="all-exports">All exports</h2>
  {apiExportsByGroup.map((group) => (
    <>
      <p><strong>{group.title}</strong></p>
      <ul>
        {group.items.map((item) => (
          <li>
            {functionPageByName.has(item.name) ? (
              <a href={functionPageByName.get(item.name)}><code>{item.label}</code></a>
            ) : (
              <code>{item.label}</code>
            )}
            {item.description ? ` - ${item.description}` : ""}
          </li>
        ))}
      </ul>
    </>
  ))}

  <h2 id="public-types">Public types</h2>
  <p>
    The exported type surface is grouped separately from the runtime entry points so you can scan
    the contract shape without mixing it into the function list.
  </p>
  {apiTypes.groups.map((group) => (
    <>
      <p><strong>{group.title}</strong></p>
      <ul>
        {group.items.map((item) => (
          <li>
            <code>{item.label}</code>
            {item.description ? ` - ${item.description}` : ""}
          </li>
        ))}
      </ul>
    </>
  ))}

  <pre><code>{`import {
${primaryPages.map((page) => `  ${page.title.replace(/\(\)$/, "")},`).join("\n")}
} from "causal-order"`}</code></pre>
</ApiLayout>
