---
import ApiLayout from "../../layouts/ApiLayout.astro";
import {
  apiExportsByGroup,
  apiNavigation,
  apiOverview,
  apiPages,
  apiTypes,
} from "../../lib/api.js";

const functionPageByName = new Map([
  ["orderEvents", apiPages.orderEvents.href],
  ["orderEventStream", apiPages.orderEventStream.href],
  ["validateEvent", apiPages.validateEvent.href],
  ["compareByCausality", apiPages.compareByCausality.href],
]);

const toc = [
  { id: "where-to-start", text: "Where to start", depth: 2 },
  { id: "entry-points", text: "Primary entry points", depth: 2 },
  { id: "all-exports", text: "All exports", depth: 2 },
  { id: "public-types", text: "Public types", depth: 2 },
];
---

<ApiLayout
  title={apiOverview.title}
  description={apiOverview.description}
  sourceUrl={apiOverview.sourceUrl}
  toc={toc}
  navigation={apiNavigation}
  currentPath="/api/"
>
  <p>
    The package currently exports one public surface from <code>src/index.ts</code>. The API is
    grouped around event ordering, streaming, validation, causality comparison, clocks, anomalies,
    and types.
  </p>

  <h2 id="where-to-start">Where to start</h2>
  <p>
    If you are using the package for the first time, start with <code>orderEvents()</code> for
    bounded replay or audit slices. Move to <code>orderEventStream()</code> when you need watermark,
    late-arrival, and correction-capable behavior.
  </p>

  <h2 id="entry-points">Primary entry points</h2>
  <ul>
    <li><a href={apiPages.orderEvents.href}><code>{apiPages.orderEvents.title}</code></a> for bounded batch ordering.</li>
    <li><a href={apiPages.orderEventStream.href}><code>{apiPages.orderEventStream.title}</code></a> for async streaming output.</li>
    <li><a href={apiPages.validateEvent.href}><code>{apiPages.validateEvent.title}</code></a> for event-envelope validation.</li>
    <li><a href={apiPages.compareByCausality.href}><code>{apiPages.compareByCausality.title}</code></a> for pairwise causal comparison.</li>
  </ul>

  <h2 id="all-exports">All exports</h2>
  {apiExportsByGroup.map((group) => (
    <>
      <p><strong>{group.title}</strong></p>
      <ul>
        {group.items.map((item) => (
          <li>
            {functionPageByName.has(item.name) ? (
              <a href={functionPageByName.get(item.name)}><code>{item.label}</code></a>
            ) : (
              <code>{item.label}</code>
            )}
            {item.description ? ` - ${item.description}` : ""}
          </li>
        ))}
      </ul>
    </>
  ))}

  <h2 id="public-types">Public types</h2>
  <p>
    The exported type surface is grouped separately from the runtime entry points so you can scan
    the contract shape without mixing it into the function list.
  </p>
  {apiTypes.groups.map((group) => (
    <>
      <p><strong>{group.title}</strong></p>
      <ul>
        {group.items.map((item) => (
          <li>
            <code>{item.label}</code>
            {item.description ? ` - ${item.description}` : ""}
          </li>
        ))}
      </ul>
    </>
  ))}

  <pre><code>{`import {
  orderEvents,
  orderEventStream,
  validateEvent,
  compareByCausality,
} from "causal-order"`}</code></pre>
</ApiLayout>
