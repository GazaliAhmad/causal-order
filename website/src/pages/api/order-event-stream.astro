---
import ApiLayout from "../../layouts/ApiLayout.astro";
import { apiNavigation, apiPages } from "../../lib/api.js";

const page = apiPages.orderEventStream;

const toc = [
  { id: "signature", text: "Signature", depth: 2 },
  { id: "usage", text: "Usage", depth: 2 },
  { id: "batch-shape", text: "Batch shape", depth: 2 },
  { id: "stream-options", text: "Stream options", depth: 2 },
];
---

<ApiLayout
  title={page.title}
  description={page.description}
  sourceUrl={page.sourceUrl}
  toc={toc}
  navigation={apiNavigation}
  currentPath={page.href}
>
  <h2 id="signature">Signature</h2>
  {page.signatures.map((signature) => (
    <pre><code>{signature}</code></pre>
  ))}

  <p>
    This is the streaming entry point for live feeds, reconnect-heavy flows, and delayed arrival
    recovery. It uses an operational watermark, not a causal truth boundary.
  </p>

  <h2 id="usage">Usage</h2>
  <pre><code>{`import { orderEventStream } from "causal-order"

for await (const batch of orderEventStream(source, {
  batchSize: 100,
  maxLateArrivalMs: 30_000n,
  lateArrivalPolicy: "flag",
})) {
  console.log(batch.events)
  console.log(batch.watermark)
  console.log(batch.anomalies)
}`}</code></pre>

  <h2 id="batch-shape">Batch shape</h2>
  <ul>
    <li><code>events</code>: ordered stream events for the flushed window.</li>
    <li><code>anomalies</code>: buffered-window anomalies and late-arrival signals.</li>
    <li><code>watermark</code>: the active operational watermark after applying lateness allowance.</li>
    <li><code>anomalyHorizon</code>: what cross-window anomaly history is still retained.</li>
    <li><code>correction</code>: present when <code>lateArrivalPolicy: "emit_correction"</code> produces a correction-capable batch.</li>
    <li><code>isFinal</code>: whether the stream has been fully drained.</li>
  </ul>

  <h2 id="stream-options">Stream options</h2>
  <ul>
    <li><code>batchSize</code>: flush size target for ready events.</li>
    <li><code>maxLateArrivalMs</code>: lateness allowance applied to the watermark signal.</li>
    <li><code>lateArrivalPolicy</code>: one of <code>flag</code>, <code>drop</code>, <code>emit_correction</code>, or <code>fail</code>.</li>
    <li><code>watermark</code>: custom watermark signal extractor.</li>
    <li>All standard <code>OrderOptions</code> also apply.</li>
  </ul>
</ApiLayout>
