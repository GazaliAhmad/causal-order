---
import ApiLayout from "../../layouts/ApiLayout.astro";
import { apiNavigation, apiPages, apiTypes } from "../../lib/api.js";

const page = apiPages.types;

const toc = [
  ...apiTypes.groups.map((group) => ({
    id: group.title.toLowerCase().replaceAll(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, ""),
    text: group.title,
    depth: 2,
  })),
];
---

<ApiLayout
  title={page.title}
  description={page.description}
  sourceUrl={page.sourceUrl}
  toc={toc}
  navigation={apiNavigation}
  currentPath={page.href}
>
  {apiTypes.groups.map((group) => (
    <>
      <h2 id={group.title.toLowerCase().replaceAll(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "")}>
        {group.title}
      </h2>
      <ul>
        {group.items.map((item) => (
          <li>
            <code>{item.label}</code>
            {item.description ? ` - ${item.description}` : ""}
          </li>
        ))}
      </ul>
    </>
  ))}

  <p>
    The confidence model used in ordered output is currently:{" "}
    {apiTypes.confidenceModel.map((item, index) => (
      <>
        <code>{item}</code>{index < apiTypes.confidenceModel.length - 1 ? ", " : "."}
      </>
    ))}
  </p>
</ApiLayout>
