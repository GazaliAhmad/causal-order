{
  "name": "causal-order",
  "version": "0.0.4",
  "description": "An event integrity library for ordering and analyzing distributed events without false certainty.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node test/run.mjs",
    "demo": "npm run build && node examples/smoke-demo.mjs",
    "examples": "npm run build && node examples/index.mjs"
  },
  "devDependencies": {
    "typescript": "^5.9.0"
  }
}
